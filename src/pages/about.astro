---
import { GradientText, Section } from "@/components";
import Base from "@/templates/Base.astro";
import { AppConfig } from "@/utils/AppConfig";
import { PERSON_ID, breadcrumbNode, personNode } from "@/utils/seo";

const title = "About — Tao Xu (hewig)";
const description =
  "About Tao Xu (hewig): a Tokyo-based software engineer and blockchain developer, former founding engineer at Trust Wallet, building Rust tools, macOS apps, and crypto wallet infrastructure.";

// Social links rendered as polished icon buttons. `fill` icons are brand
// glyphs; the rest are drawn with strokes.
const socials = [
  {
    label: "GitHub",
    href: AppConfig.social.github,
    fill: true,
    path: "M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.36-1.34-1.73-1.34-1.73-1.09-.73.08-.71.08-.71 1.2.08 1.84 1.21 1.84 1.21 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.83 0-1.29.47-2.34 1.23-3.17-.12-.3-.53-1.51.12-3.15 0 0 1-.32 3.3 1.21a11.5 11.5 0 0 1 6 0c2.28-1.53 3.29-1.21 3.29-1.21.65 1.64.24 2.85.12 3.15.77.83 1.23 1.88 1.23 3.17 0 4.53-2.8 5.53-5.48 5.82.43.37.81 1.1.81 2.22 0 1.6-.01 2.9-.01 3.29 0 .31.22.68.83.56A12.02 12.02 0 0 0 24 12.29C24 5.78 18.63.5 12 .5z",
  },
  {
    label: "X / Twitter",
    href: AppConfig.social.twitter,
    fill: true,
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  },
  {
    label: "Telegram",
    href: AppConfig.social.telegram,
    fill: true,
    path: "M21.94 4.3 18.9 19.6c-.23 1.02-.84 1.27-1.7.79l-4.7-3.46-2.27 2.18c-.25.25-.46.46-.94.46l.33-4.78 8.7-7.86c.38-.34-.08-.53-.59-.19L6.78 13.2l-4.64-1.45c-1.01-.32-1.03-1.01.21-1.5l18.13-6.99c.84-.31 1.58.2 1.46 1.04z",
  },
  {
    label: "Newsletter",
    href: AppConfig.social.newsletter,
    fill: false,
    path: '<path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1.4"></circle>',
  },
  {
    label: "Email",
    href: `mailto:${AppConfig.social.email}`,
    fill: false,
    path: '<rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3.5 6.5 8.5 6 8.5-6"></path>',
  },
];

const chains = [
  { src: "/assets/images/btc.svg", alt: "Bitcoin" },
  { src: "/assets/images/eth.svg", alt: "Ethereum" },
  { src: "/assets/images/bnb.svg", alt: "BNB Chain" },
  { src: "/assets/images/sui.svg", alt: "Sui" },
  { src: "/assets/images/sol.svg", alt: "Solana" },
];

const jsonLd = [
  { "@type": "ProfilePage", mainEntity: { "@id": PERSON_ID } },
  personNode(),
  breadcrumbNode([
    { name: "Home", path: "/" },
    { name: "About", path: "/about/" },
  ]),
];
---

<Base head={{ title, description, type: "profile", jsonLd }}>
  <Section as="article">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
      <img
        class="h-28 w-28 shrink-0 rounded-full shadow-glow ring-1 ring-line"
        src="/assets/images/avatar.png"
        alt="Tao Xu"
        width="112"
        height="112"
        loading="eager"
      />
      <div>
        <div class="eyebrow">// about</div>
        <h1 class="mt-2 text-3xl font-bold text-ink">Tao <GradientText>Xu</GradientText></h1>
        <p class="mt-1 text-muted">Blockchain &amp; software engineer · Tokyo, Japan</p>
      </div>
    </div>

    <div class="prose mt-8 max-w-none dark:prose-invert prose-headings:text-accent prose-a:text-accent">
      <p>
        I'm Tao Xu (also known online as <strong>hewig</strong> / hewigovens) — a
        Tokyo-based software engineer and blockchain developer. I was a founding
        engineer at <a href="https://trustwallet.com/">Trust Wallet</a>, where I
        helped build crypto wallet infrastructure used by millions of people.
      </p>

      <p>
        Today I design scalable blockchain infrastructure, cross-platform SDKs,
        and decentralized applications across Ethereum, Solana, Bitcoin, and
        other leading networks — and I build native macOS and iOS apps and Rust
        developer tooling on the side.
      </p>

      <h2>What I work on</h2>
      <ul>
        <li>
          <strong>Crypto &amp; wallet infrastructure</strong> — low-level wallet
          libraries, hardware-wallet protocols, and chain primitives in Rust and
          C++ (Wallet Core, <a href="/projects/hw-core/">hw-core</a>,
          <a href="/projects/solana-primitives/">Solana Primitives</a>).
        </li>
        <li>
          <strong>Rust tools &amp; libraries</strong> — small, focused crates and
          developer tooling (<a href="/projects/reqwest-enum/">reqwest-enum</a>,
          <a href="/projects/aya-devcontainer/">Aya DevContainer</a>).
        </li>
        <li>
          <strong>macOS &amp; iOS apps</strong> — native utilities like
          <a href="/projects/app-detective/">App Detective</a>,
          <a href="https://ghosttile.hewig.dev">GhostTile</a>,
          <a href="/projects/miso/">Miso</a>, and
          <a href="https://fourplexlabs.github.io/AnyTime">Anytime</a>.
        </li>
      </ul>

      <h2>Consulting</h2>
      <p>
        I also take on selective technical consulting — blockchain and crypto
        wallet engineering, system architecture, and security reviews. See the
        <a href="/consulting/">consulting page</a> (日本語) for details.
      </p>
    </div>

    <div class="mt-10">
      <div class="eyebrow">// networks</div>
      <div class="mt-3 flex flex-wrap items-center gap-4">
        {chains.map((c) => <img src={c.src} alt={c.alt} class="h-8 w-8" loading="lazy" />)}
      </div>
    </div>

    <div class="mt-10">
      <div class="eyebrow">// connect</div>
      <div class="mt-3 flex flex-wrap gap-3">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
              class="flex h-11 w-11 items-center justify-center rounded-full border border-line bg-panel text-muted transition hover:border-accent hover:text-accent hover:-translate-y-0.5"
            >
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5"
                fill={s.fill ? "currentColor" : "none"}
                stroke={s.fill ? "none" : "currentColor"}
                stroke-width={s.fill ? "0" : "1.8"}
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={s.fill ? `<path d="${s.path}"></path>` : s.path}
              />
            </a>
          ))
        }
      </div>
    </div>
  </Section>
</Base>
