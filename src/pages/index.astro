---
import type { IFrontmatter, MarkdownInstance } from "@/components";

import { SubscribeForm } from "@/partials/SubscribeForm";
import { Hero } from "@/partials/Hero";
import { ProjectList } from "@/partials/ProjectList";
import { RecentPosts } from "@/partials/RecentPosts";
import Base from "@/templates/Base.astro";
import { AppConfig } from "@/utils/AppConfig";
import { publishedPosts, sortByDate } from "@/utils/Posts";
import { personNode, websiteNode } from "@/utils/seo";

const allPosts = Object.values(import.meta.glob<MarkdownInstance<IFrontmatter>>("./posts/*.md", { eager: true }));
const sortedPosts = sortByDate(publishedPosts(allPosts));
const recentPosts = sortedPosts.slice(0, 6);

const title = `${AppConfig.name} — Blockchain & Software Engineer in Tokyo`;
const description = AppConfig.description;
---

<Base head={{ title, description, jsonLd: [websiteNode(), personNode()] }}>
  <Hero />
  <ProjectList />
  <RecentPosts postList={recentPosts} perColumn={3} />
  <SubscribeForm />
</Base>
